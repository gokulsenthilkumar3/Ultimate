# GrowthTrack Ultimate — Backend Environment Variables

# Server
PORT=3001
NODE_ENV=production

# Supabase (get from: supabase.com → your project → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/ultimate?schema=public"

# Security
API_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://gokulsenthilkumar3.github.io
